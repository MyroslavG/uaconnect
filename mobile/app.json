{
  "expo": {
    "name": "Kolo",
    "slug": "kolo",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/kolo-logo.png",
    "userInterfaceStyle": "automatic",
    "scheme": "kolo",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.kolo.mobile",
      "associatedDomains": [
        "applinks:koloapp.ca"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "app.kolo.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/kolo-logo.png",
        "backgroundColor": "#291C0E"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "koloapp.ca",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "splash": {
      "image": "./assets/kolo-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#E1D4C2"
    },
    "web": {
      "favicon": "./assets/kolo-logo.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-apple-authentication",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Choose a business logo for your Kolo profile."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "a0d51185-a0b8-4839-82bf-b70fef0b64db"
      }
    },
    "owner": "myroslavv"
  }
}
